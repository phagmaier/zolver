// Example: re-solve a turn subgame after check-check on the flop.
// Run with:  ./zig-out/bin/Poker resolve examples/turn.zon
.{
    .board = "AhKsQd",
    .pot   = 50,
    .stack = 200,
    .p1    = "JJ+, AKs",
    .p2    = "TT+, AQs+",
    .iters = 50,
    .flop  = .{ .path = "x x" },
    .turn  = .{ .card = "Th" },
}
